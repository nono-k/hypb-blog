---
interface Props {
  src: string;
  title: string;
  sub?: string;
}

const { src, title, sub } = Astro.props;
---

<div class="iframe">
  <iframe
    style="width: 100%; height: 100%;"
    title={title}
    src={src}
    loading="lazy"
    allowtransparency="true"
    allowfullscreen="true"
    frameborder="0"
  >
  </iframe>
  {sub && <p class="iframe__sub">{sub}</p>}
</div>

<style lang="scss">
  .iframe {
    width: 100%;
    height: 100%;
    aspect-ratio: 16 / 9;
    margin-bottom: 2rem;

    &__sub {
      font-size: 0.75rem;
      text-align: center;
    }
  }
  @include mixin.mobile {
    .iframe {
      aspect-ratio: 1 / 1;
    }
  }
</style>